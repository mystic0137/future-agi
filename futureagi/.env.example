# =============================================================================
# FutureAGI Core Backend - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All services now use a single .env file (no separate .env.worker needed)
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
ENV_TYPE=local                    # local | staging | prod
APP_URL=localhost:3031
SERVICE_TYPE=backend              # backend | worker | beat | temporal-worker

# -----------------------------------------------------------------------------
# Multi-Region (leave defaults for self-hosted / single-region)
# -----------------------------------------------------------------------------
# REGION identifies this deployment instance (default: "us")
REGION=us
# CLOUD_DEPLOYMENT enables cloud multi-region UI. Values: US | EU | DEV | "" (self-hosted)
# Set to "DEV" for local testing with region selector visible.
CLOUD_DEPLOYMENT=DEV
# Comma-separated list of regions: code:label:app_url
# Both point to localhost for local testing.
AVAILABLE_REGIONS=us:US (Ohio):http://localhost:3031,eu:EU (Frankfurt):http://localhost:3031

# For development with single temporal worker (optional)
# COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml

# Skip non-essential checks for faster dev startup
FAST_STARTUP=true

# -----------------------------------------------------------------------------
# Local Development Performance Settings
# -----------------------------------------------------------------------------
# Number of Granian workers (default: 1 for dev, increase for production)
GRANIAN_WORKERS=1

# Enable/disable HTTP server (Granian ASGI)
# Set to false for gRPC-only microservice
ENABLE_HTTP=true

# Enable/disable gRPC server (disable to save memory in local dev)
# Set to true if you need gRPC functionality
ENABLE_GRPC=false

# Microservice configurations:
#   HTTP only:  ENABLE_HTTP=true,  ENABLE_GRPC=false (default for local dev)
#   gRPC only:  ENABLE_HTTP=false, ENABLE_GRPC=true
#   Both:       ENABLE_HTTP=true,  ENABLE_GRPC=true  (default for prod)

# -----------------------------------------------------------------------------
# Docker Compose Port Mappings (optional - defaults shown)
# -----------------------------------------------------------------------------
# BACKEND_PORT=8000
# SERVING_PORT=8080
# PG_PORT=5432
# CH_HTTP_PORT=8123
# CH_PORT=9000
# RABBITMQ_PORT=5672
# RABBITMQ_MANAGEMENT_PORT=15672
# MINIO_API_PORT=9005
# MINIO_CONSOLE_PORT=9006
# TEMPORAL_PORT=7233
# TEMPORAL_UI_PORT=8085
# JAEGER_UI_PORT=16686          # (dev only - docker-compose.dev.yml)
# JAEGER_OTLP_GRPC_PORT=4317    # (dev only)
# JAEGER_OTLP_HTTP_PORT=4318    # (dev only)

# -----------------------------------------------------------------------------
# Test Environment (uses different ports to avoid collision with dev)
# -----------------------------------------------------------------------------
# Copy .env.test.local for running tests locally:
#   cp .env.test.local .env.test.local  (if not exists)
#
# Test ports (to avoid collision with dev):
#   PostgreSQL: 15432 (dev: 5432)
#   ClickHouse: 19000 (dev: 9000)
#   ClickHouse HTTP: 18123 (dev: 8123)
#
# Run tests with:
#   source .env.test.local && pytest

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
PG_DB=tfc
PG_USER=user
PG_PASSWORD=password
PG_HOST=db                        # Use 'db' for docker, 'localhost' for local
PG_PORT=5432
PGBOUNCER_HOST=pgbouncer
PGBOUNCER_PORT=6432

# -----------------------------------------------------------------------------
# Read Replica (optional — not needed for local dev)
# -----------------------------------------------------------------------------
# When set, Django routes all ORM reads to this PgBouncer instance.
# Unset = all reads go to the primary (default behavior).
# PGBOUNCER_READ_HOST=pgbouncer   # same pgbouncer locally, pgbouncer-read-service in k8s
# PGBOUNCER_READ_PORT=6432

# -----------------------------------------------------------------------------
# ClickHouse (Analytics Database)
# -----------------------------------------------------------------------------
CH_HOST=clickhouse                # Use 'clickhouse' for docker, 'localhost' for local
CH_PORT=9000
CH_HTTP_PORT=8123
CH_USERNAME=default
CH_PASSWORD=
CH_DATABASE=default
CH_USE_REPLICATED_ENGINES=false   # true only if shard/replica macros are configured
# Memory limit for ClickHouse container (default: 2g, increase if OOM)
# CLICKHOUSE_MEM_LIMIT=2g

# reCAPTCHA (enable + configure for public deployments)
RECAPTCHA_ENABLED=false
RECAPTCHA_SECRET_KEY=
VITE_GOOGLE_SITE_KEY=

# -----------------------------------------------------------------------------
# RabbitMQ (Message Queue)
# -----------------------------------------------------------------------------
RABBITMQ_USER=user
RABBITMQ_PASSWORD=password
CELERY_BROKER_URL=amqp://user:password@rabbitmq:5672/%2F

# -----------------------------------------------------------------------------
# Redis (Distributed Locking & State)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0        # Use 'redis' for docker, 'localhost' for local
REDIS_PORT=6379
REDIS_LOCK_URL=redis://redis:6379/1
REDIS_STATE_URL=redis://redis:6379/2

# -----------------------------------------------------------------------------
# Temporal (Workflow Engine)
# -----------------------------------------------------------------------------
TEMPORAL_HOST=temporal:7233       # Use 'temporal:7233' for docker, 'localhost:7233' for local
TEMPORAL_NAMESPACE=default
TEMPORAL_LOG_LEVEL=info
TEMPORAL_TEST_EXECUTION_ENABLED=true
TEMPORAL_MAX_CONCURRENT_ACTIVITIES=500
TEMPORAL_MAX_CONCURRENT_WORKFLOW_TASKS=500

# For single worker development mode (polls all queues)
# TEMPORAL_ALL_QUEUES=true

# Resource-based tuning (optional - disabled by default due to known SDK polling bug)
# See: https://github.com/temporalio/sdk-python/issues/1268
# TEMPORAL_RESOURCE_TUNING_ENABLED=false
# TEMPORAL_TARGET_MEMORY_USAGE=0.8
# TEMPORAL_TARGET_CPU_USAGE=1.0

# Per-queue concurrency settings (optional - defaults shown)
# TEMPORAL_DEFAULT_MAX_ACTIVITIES=100
# TEMPORAL_DEFAULT_MAX_WORKFLOWS=100
# TEMPORAL_TASKS_L_MAX_ACTIVITIES=50
# TEMPORAL_TASKS_L_MAX_WORKFLOWS=50
# TEMPORAL_TASKS_XL_MAX_ACTIVITIES=10
# TEMPORAL_TASKS_XL_MAX_WORKFLOWS=20
# TEMPORAL_TASKS_S_MAX_ACTIVITIES=200
# TEMPORAL_TASKS_S_MAX_WORKFLOWS=200
# TEMPORAL_TRACE_MAX_ACTIVITIES=100
# TEMPORAL_TRACE_MAX_WORKFLOWS=100
# TEMPORAL_COMPASS_MAX_ACTIVITIES=50
# TEMPORAL_COMPASS_MAX_WORKFLOWS=50

# Dev mode concurrency (used by docker-compose.dev.yml)
# TEMPORAL_DEV_MAX_ACTIVITIES=20
# TEMPORAL_DEV_MAX_WORKFLOWS=20

# -----------------------------------------------------------------------------
# MinIO (Object Storage)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_NAME=fi-content-dev
MINIO_REGION=us-east-1

# -----------------------------------------------------------------------------
# Model Serving
# -----------------------------------------------------------------------------
MODEL_SERVING_URL=http://serving:8080
MODEL_SERVING_BASE_URL=http://serving:8080/model/v1

# -----------------------------------------------------------------------------
# LLM API Keys (add the ones you need)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...
GROQ_API_KEY=gsk_...
PERPLEXITY_API_KEY=pplx-...
XAI_API_KEY=xai-...

# -----------------------------------------------------------------------------
# AWS Configuration
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_DEFAULT_REGION=us-east-1
AWS_BEDROCK_REGION=us-west-2
S3_FOR_DATA=your-bucket-name
AWS_BUCKET_NAME=your-bucket-name

# -----------------------------------------------------------------------------
# Google Cloud / Vertex AI (optional)
#
# Two independent paths use Google creds; pick whichever applies:
#
# 1. Vertex via the gateway — provider config lives in
#    agentcc-gateway/config.yaml. The gateway interpolates any ${ENV_VAR} at
#    load time, so just add whatever env vars your config.yaml references
#    (e.g. GOOGLE_ACCESS_TOKEN=...) here. The recommended pattern is a
#    short-lived Bearer token from `gcloud auth print-access-token`, rotated
#    by a sidecar. See INSTALLATION.md → "Vertex AI".
#
# 2. Direct Vertex from agentic_eval (bypasses the gateway) — that code path
#    reads GOOGLE_APPLICATION_CREDENTIALS as a JSON keyfile path. If you use
#    it, set the env below AND arrange for the file to exist inside the
#    container via a local compose override. DO NOT commit the keyfile and
#    DO NOT bake it into a shared/public image.
# -----------------------------------------------------------------------------
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=True
# GOOGLE_APPLICATION_CREDENTIALS=/path/inside/container/credentials.json

# -----------------------------------------------------------------------------
# Email (Mailgun)
# -----------------------------------------------------------------------------
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_SENDER_DOMAIN=mail.yourdomain.com
DEFAULT_FROM_EMAIL=noreply@mail.yourdomain.com
SERVER_EMAIL=noreply@mail.yourdomain.com

# -----------------------------------------------------------------------------
# Stripe (Payments)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_REDIRECT_DOMAIN=http://localhost:3031
WEBHOOK_SECRET=whsec_...
BUSINESS_MONTHLY_STRIPE_PRICE_ID=price_...
BUSINESS_MONTHLY_STRIPE_PRICE_IDS_ALL=price_...
BUSINESS_YEARLY_STRIPE_PRICE_ID=price_...
BUSINESS_YEARLY_STRIPE_PRICE_IDS_ALL=price_...

# -----------------------------------------------------------------------------
# OAuth Credentials
# -----------------------------------------------------------------------------
AUTH0_CLIENT_ID=your-google-oauth-client-id
AUTH0_CLIENT_SECRET=your-google-oauth-client-secret
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
# MICROSOFT_CLIENT_ID=your-microsoft-oauth-client-id
# MICROSOFT_CLIENT_SECRET=your-microsoft-oauth-client-secret

# -----------------------------------------------------------------------------
# Slack Webhooks
# -----------------------------------------------------------------------------
SLACK_WEBHOOK_CHANNEL=https://hooks.slack.com/services/...
ERROR_LOGS_WEBHOOK=https://hooks.slack.com/services/...

# -----------------------------------------------------------------------------
# URLs (derived automatically from ENV_TYPE + APP_URL if not set)
# -----------------------------------------------------------------------------
# BASE_URL=http://localhost:8000
# WEBSOCKET_ENDPOINT=http://localhost/call-websocket/
# MINIO_URL=http://localhost:9005
# UPLOAD_BUCKET_NAME=fi-content-dev

# -----------------------------------------------------------------------------
# Sentry (Error Tracking)
# -----------------------------------------------------------------------------
SENTRY_DSN=

# -----------------------------------------------------------------------------
# OpenTelemetry (Distributed Tracing & Logs)
# -----------------------------------------------------------------------------
# Enable/disable OpenTelemetry tracing (default: false)
# For local tracing, use docker-compose.observability.yml which auto-enables it
OTEL_ENABLED=false

# Service name shown in traces (each service has its own default)
# OTEL_SERVICE_NAME=futureagi-backend

# -----------------------------------------------------------------------------
# OTLP Exporter Configuration
# -----------------------------------------------------------------------------
# Protocol: "grpc" (default, port 4317) or "http/protobuf" (port 4318)
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# ===== JAEGER (Local Development) =====
# Jaeger supports OTLP natively (v1.35+)
# gRPC endpoint (recommended):
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
# HTTP endpoint (alternative):
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
#
# Jaeger UI: http://localhost:16686

# ===== GRAFANA TEMPO (Production) =====
# Tempo is designed for high-volume production tracing
# gRPC endpoint (recommended):
# OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
# HTTP endpoint (alternative):
# OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
#
# For distributed Tempo (Kubernetes):
# OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo-distributor:4317
#
# Tempo requires Grafana for UI - traces viewable in Grafana Explore

# ===== GRAFANA ALLOY / OTEL COLLECTOR (Recommended for Production) =====
# Use a collector for buffering, batching, and routing to multiple backends
# OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy:4317
# or
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# -----------------------------------------------------------------------------
# Trace Sampling (reduce volume in production)
# -----------------------------------------------------------------------------
# parentbased_traceidratio = sample based on parent + ratio (recommended)
# OTEL_TRACES_SAMPLER=parentbased_traceidratio
# OTEL_TRACES_SAMPLER_ARG=1.0    # 1.0 = 100%, 0.1 = 10%, 0.01 = 1%

# -----------------------------------------------------------------------------
# Log-Trace Correlation (OTLP Log Export)
# -----------------------------------------------------------------------------
# Enable OTLP log export for automatic log-trace correlation
# Logs will be sent to the same endpoint as traces
# OTEL_LOGS_ENABLED=false

# Override logs endpoint (defaults to OTEL_EXPORTER_OTLP_ENDPOINT)
# OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://tempo:4317

# Log level for OTLP export (logs below this level are not exported)
# OTEL_PYTHON_LOG_LEVEL=INFO

# Note: Even without OTEL_LOGS_ENABLED, all logs include trace_id and span_id
# fields for correlation. OTLP export sends logs directly to the collector
# for backends that support it (Grafana Loki via Tempo, etc.)

# -----------------------------------------------------------------------------
# Quick Start Commands
# -----------------------------------------------------------------------------
# Local development with Jaeger:
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml -f docker-compose.observability.yml up
#   View traces: http://localhost:16686 (Jaeger UI)
#
# Production with Grafana Tempo + Loki:
#   Set OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
#   Set OTEL_LOGS_ENABLED=true (optional, for OTLP log export)
#   View in Grafana Explore with TraceQL

# -----------------------------------------------------------------------------
# Mixpanel (Analytics)
# -----------------------------------------------------------------------------
MIX_PANEL_TOKEN=your-mixpanel-token

# -----------------------------------------------------------------------------
# PostHog (Product Analytics, Session Replay, Feature Flags)
# -----------------------------------------------------------------------------
POSTHOG_API_KEY=phc_your_posthog_project_api_key
POSTHOG_HOST=https://us.i.posthog.com    # or https://eu.i.posthog.com or self-hosted

# -----------------------------------------------------------------------------
# Voice Provider Selection
# -----------------------------------------------------------------------------
SYSTEM_VOICE_PROVIDER=livekit            # vapi | livekit

# -----------------------------------------------------------------------------
# VAPI (Voice AI)
# -----------------------------------------------------------------------------
VAPI_API_KEY=your-vapi-key
VAPI_API_BASE_URL=https://api.vapi.ai
VAPI_PHONE_NUMBER_ID=your-phone-id
VAPI_INDIAN_PHONE_NUMBER_ID=your-indian-phone-id

# -----------------------------------------------------------------------------
# GitHub
# -----------------------------------------------------------------------------
GITHUB_ACCESS_TOKEN=github_pat_...

# -----------------------------------------------------------------------------
# Celery Worker Settings (optional - only if using Celery)
# -----------------------------------------------------------------------------
# CELERY_DEFAULT_CONCURRENCY=16
# CELERY_DEFAULT_MAX_TASKS=1000
# CELERY_TASKS_XL_CONCURRENCY=8
# CELERY_TASKS_XL_MAX_TASKS=100
# CELERY_TASKS_L_CONCURRENCY=8
# CELERY_TASKS_L_MAX_TASKS=100
# CELERY_TASKS_S_CONCURRENCY=16
# CELERY_TASKS_S_MAX_TASKS=1000
# CELERY_TRACE_INGESTION_CONCURRENCY=16
# CELERY_TRACE_INGESTION_MAX_TASKS=1000
# CELERY_AGENT_COMPASS_CONCURRENCY=8
# CELERY_AGENT_COMPASS_MAX_TASKS=100

# -----------------------------------------------------------------------------
# LiveKit (Real-time Voice/Video)
# -----------------------------------------------------------------------------
# The LiveKit cluster (server, SIP bridge, egress) runs on a remote Linux
# server — see docker-compose.livekit.yml and docs/LIVEKIT_SIP_SETUP.md.
#
# NOTE: macOS Docker Desktop cannot forward inbound UDP (RTP) from Twilio
# to the SIP bridge. The cluster MUST run on Linux with host networking.

# Core — point to the remote LiveKit cluster
LIVEKIT_URL=wss://your-livekit-host:7880
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret-min-32-chars
INTERNAL_API_SECRET=your-internal-api-secret

# Backend callback URL — included in agent dispatch metadata so the
# agent worker knows where to send transcripts/signals back to.
# For local dev with a shared agent worker, use a tunnel URL (e.g. ngrok).
LIVEKIT_BACKEND_CALLBACK_URL=http://localhost:8000

# SIP trunk IDs — provisioned on the LiveKit server (livekit-infra repo),
# shared by all backends connecting to the same cluster.
SIP_INBOUND_TRUNK_ID=your-inbound-trunk-id
SIP_OUTBOUND_TRUNK_ID=your-outbound-trunk-id
SIP_CPS_BATCH_SIZE=1                  # SIP calls-per-second batch size

# Egress recordings are written directly to the main S3 bucket (AWS_BUCKET_NAME).
# No separate MinIO/storage service needed.

# STT/TTS Providers
TTS_PROVIDER=cartesia                    # cartesia (default). Used by voice catalog + agent worker.
DEEPGRAM_API_KEY=dg-...
CARTESIA_API_KEY=sk-cart-...
# ELEVENLABS_API_KEY=sk-el-...           # Optional

# LiveKit cost tracking rates
LIVEKIT_STT_RATE_PER_SECOND=0.000128
LIVEKIT_TTS_RATE_PER_CHAR=0.000011
LIVEKIT_STORAGE_RATE_PER_MB=0.000023

# -----------------------------------------------------------------------------
# Application Limits
# -----------------------------------------------------------------------------
DEFAULT_APP_LIMIT=100
DEFAULT_ORG_LIMIT=5
DEFAULT_PHONE_ORG_LIMIT=5

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
INTEGRATION_ENCRYPTION_KEY=your-fernet-key            # Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GUARDRAILS_TOKEN=your-guardrails-token

# -----------------------------------------------------------------------------
# agentcc Gateway — User-Facing (LLM Proxy for customers)
# -----------------------------------------------------------------------------
AGENTCC_GATEWAY_PORT=8090
AGENTCC_GATEWAY_PUBLIC_URL=https://your-gateway-domain.com
AGENTCC_GATEWAY_INTERNAL_URL=http://agentcc-gateway:8090
AGENTCC_ADMIN_TOKEN=agentcc-admin-secret
AGENTCC_WEBHOOK_SECRET=test-webhook-secret

# -----------------------------------------------------------------------------
# Internal AI Service Key — for platform AI calls (evals, analysis, annotation)
# Uses the SAME agentcc-gateway, but with a dedicated API key tagged as "internal".
# Internal calls bypass user quota but are still cost-tracked.
# -----------------------------------------------------------------------------
AGENTCC_INTERNAL_URL=http://agentcc-gateway:8090
AGENTCC_INTERNAL_API_KEY=fi-internal-dev-key-change-in-prod

# -----------------------------------------------------------------------------
# Falcon AI (Agent Chat)
# -----------------------------------------------------------------------------
FALCON_AI_PROVIDER=bedrock                # anthropic | bedrock | openai | vertex_ai
FALCON_AI_MODEL=your-model-id
# FALCON_AI_MAX_TOKENS=16384
# FALCON_AI_TEMPERATURE=0.2
# FALCON_AI_EXTENDED_THINKING=false


# -----------------------------------------------------------------------------
# Agent Eval Timeout (seconds)
# Maximum time for agent evaluator to complete (default: 300)
# -----------------------------------------------------------------------------
# AGENT_EVAL_TIMEOUT=300
